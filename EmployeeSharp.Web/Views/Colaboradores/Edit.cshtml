@model EmployeeSharp.Web.Models.ColaboradorViewModel

<form id="editColaboradorForm" asp-action="Edit" asp-controller="Colaboradores" method="post">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)

    <div class="form-group">
        <label asp-for="Nome">Nome:</label>
        <input asp-for="Nome" class="form-control" data-val="true" data-val-length="O nome deve ter entre 5 e 20 caracteres." data-val-length-min="5" data-val-length-max="20" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email">Email:</label>
        <input asp-for="Email" class="form-control" data-val="true" data-val-email="O campo Email deve ser um endereço de email válido." />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Telefone">Telefone:</label>
        <input asp-for="Telefone" class="form-control" data-val="true" data-val-regex="O campo Telefone deve conter 11 números." data-val-regex-pattern="^\d{11}$" />
        <span asp-validation-for="Telefone" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CargoId">Cargo:</label>
        <select asp-for="CargoId" class="form-control" data-val="true" data-val-required="O campo Cargo é obrigatório.">
            <option value="">Selecione um cargo</option>
            @foreach (var cargo in Model.Cargos)
            {
                <option value="@cargo.Id">@cargo.Nome</option>
            }
        </select>
        <span asp-validation-for="CargoId" class="text-danger"></span>
    </div>

    <div class="modal-footer">
        <a class="btn btn-secondary" href="/Colaboradores/Index">Cancelar</a>
        <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
</form>