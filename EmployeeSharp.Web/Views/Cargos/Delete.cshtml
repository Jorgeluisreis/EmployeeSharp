@model EmployeeSharp.Domain.Entities.Cargo

<div class="modal-header">
    <h5 class="modal-title" id="deleteModalLabel">Deletar Cargo</h5>
</div>
<div class="modal-body">
    <h6>Tem certeza que deseja deletar este cargo?</h6>
    <h5 class="text-muted">@Model.Nome</h5>
    <form id="deleteCargoForm" asp-action="DeleteConfirmed">
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <button type="submit" class="btn btn-danger btn-sm">Deletar</button>
            <button type="button" id="cancelDeleteButton" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancelar</button>
        </div>
    </form>
</div>
